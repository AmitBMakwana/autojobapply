{
  "manifest_version": 3,
  "name": "JobForge AI: Assistant on Every Job Page",
  "version": "2.0.0",
  "description": "Auto-detects job postings, scores your fit, tailors your resume/cover letter live, and helps you autofill applications.",
  "permissions": ["activeTab", "scripting", "storage", "downloads", "notifications"],
  "host_permissions": [
    "http://127.0.0.1:3001/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["panel.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "JobForge AI"
  },
  "icons": {
    "128": "icon.png"
  }
}
